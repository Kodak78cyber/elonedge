# =============================================================================
# Required environment variables for ElonEdge.
# Copy this file to .env (local dev) or paste these keys into your hosting
# provider's environment-variable dashboard (production).
# =============================================================================

# --- Database (Neon Postgres) -------------------------------------------------
# Connection-pooled URL used by the Next.js app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct (un-pooled) URL used by Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- User session JWT ---------------------------------------------------------
# Used to sign user session cookies (jose / HS256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# --- Admin login credentials --------------------------------------------------
# Whoever knows these can sign in at /admin/login and edit users, assets,
# and homepage copy. Keep them secret. Use a strong password.
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"

# --- Public app config --------------------------------------------------------
# Used for absolute URLs in meta tags, etc. Set to your real domain on prod.
NEXT_PUBLIC_APP_NAME="ElonEdge"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
